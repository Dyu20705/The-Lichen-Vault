# Optional. Enables Gemini-powered archival observation entries.
# When omitted, the app remains functional through local fallback observations.
GEMINI_API_KEY=""

# Optional. Gemini model and bounded model-call behavior.
GEMINI_MODEL="gemini-2.5-flash"
MODEL_TIMEOUT_MS="8000"
MAX_MODEL_ATTEMPTS="2"

# Optional. Applies only when a real model key is configured.
MODEL_RATE_LIMIT_WINDOW_MS="60000"
MODEL_RATE_LIMIT_MAX="12"

# Optional. Public URL for deployments that need self-referential links.
# In Cloud Run, inject secrets and service URLs through deployment configuration.
APP_URL="http://localhost:3000"
